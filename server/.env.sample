MONGODB_URL=your_mongodb_uri
PORT=6600
SERVER_URL=http://localhost:6600/api/files
CLIENT_URL=http://localhost:5173
NODE_ENV=development

JWT_SECRET=your_secret_jwt_key

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
AWS_BUCKET_NAME=your_bucket_name

# Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords — use that 16-char value for MAIL_PASS (no spaces).
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false

FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:6600
